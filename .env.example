# =============================================================================
# Feed Design Generator - Server-side environment variables
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
#
# IMPORTANT (security): These are SERVER-SIDE secrets. Do NOT add the
# NEXT_PUBLIC_ prefix to any of them — variables prefixed with NEXT_PUBLIC_
# are bundled into the client and would leak credentials. All AI / storage
# calls happen only in server route handlers.
# =============================================================================

# --- Database (PostgreSQL serverless, pooled endpoint e.g. Neon/Supabase) ---
# Use a POOLED connection string (PgBouncer / HTTP driver) for serverless
# RUNTIME access (Prisma `db.url`). This keeps connections from exhausting the
# database across short-lived serverless function invocations.
DATABASE_URL="postgresql://user:password@host:5432/feed_design_generator?sslmode=require&pgbouncer=true"

# DIRECT (non-pooled) connection string used ONLY by migrations
# (`prisma migrate` / `prisma db push`), which cannot run over PgBouncer in
# transaction pooling mode. Maps to Prisma `db.directUrl`. With Neon/Supabase
# this is the direct (port 5432, non-pooler) endpoint.
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/feed_design_generator?sslmode=require"

# --- External AI services (accessed only from server) ---
# This project speaks the OpenAI-compatible chat API. With OpenRouter set:
#   LLM_API_BASE_URL="https://openrouter.ai/api/v1"
#   QUALITY_EVALUATOR_API_BASE_URL="https://openrouter.ai/api/v1"
# and use the same OpenRouter key for both. Model defaults to openai/gpt-4o-mini
# when *_MODEL is unset.

# LLM provider (GPT-4o-class) for copy generation & brief analysis.
LLM_API_KEY=""
LLM_API_BASE_URL=""
# Optional model slug (e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet).
LLM_MODEL=""

# Image generation provider (Flux Pro-class).
# NOTE: OpenRouter has no standard image endpoint — the built-in adapter returns
# a placeholder image. Wire a real provider here when available.
IMAGE_GEN_API_KEY=""
IMAGE_GEN_API_BASE_URL=""
IMAGE_GEN_MODEL=""

# Background removal provider (Remove.bg-class).
BACKGROUND_REMOVAL_API_KEY=""
BACKGROUND_REMOVAL_API_BASE_URL=""

# Quality evaluator provider — SEPARATE "Creative Director" AI role used by the
# Design Intelligence layer to critique rendered variations (distinct from the
# copy LLM and image generators). Server-side only.
QUALITY_EVALUATOR_API_KEY=""
QUALITY_EVALUATOR_API_BASE_URL=""
# Optional model slug for the evaluator (defaults to openai/gpt-4o-mini).
QUALITY_EVALUATOR_MODEL=""

# --- Object storage (S3-compatible, e.g. Cloudflare R2) ---
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# --- Auth / session ---
# Secret used to sign sessions / JWTs for endpoint authentication.
AUTH_SECRET=""
